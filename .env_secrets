# Exports secrets stored in macOS Keychain as environment variables.
# Secrets never touch disk in plaintext — they live in the encrypted keychain.
#
# Usage:
#   secret-set GITHUB_TOKEN ghp_abc123...   # store a secret
#   secret-get GITHUB_TOKEN                 # retrieve a secret
#   secret-del GITHUB_TOKEN                 # remove a secret
#   secret-list                             # list all managed secrets
#
# Secrets are automatically exported as env vars on shell startup.

# Keychain service prefix to namespace our secrets
_SECRET_SERVICE_PREFIX="env-secret"

_secret_name_is_valid() {
  [[ "$1" =~ '^[A-Za-z_][A-Za-z0-9_]*$' ]]
}

_secret_names() {
  emulate -L zsh
  setopt localoptions typesetsilent
  unsetopt aliases xtrace verbose

  local line prefix name
  prefix="\"svce\"<blob>=\"${_SECRET_SERVICE_PREFIX}:"

  while IFS= read -r line; do
    [[ "$line" == *"$prefix"* ]] || continue
    name="${line#*$prefix}"
    name="${name%%\"*}"
    _secret_name_is_valid "$name" || continue
    print -r -- "$name"
  done < <(command security dump-keychain 2>/dev/null)
}

secret-set() {
  local name="$1" secret_value="$2"
  if [[ -z "$name" || -z "$secret_value" ]]; then
    echo "Usage: secret-set NAME VALUE" >&2
    return 1
  fi
  if ! _secret_name_is_valid "$name"; then
    echo "Secret names must match [A-Za-z_][A-Za-z0-9_]*" >&2
    return 1
  fi
  # Delete existing entry if present, then add new one
  command security delete-generic-password -a "$USER" -s "${_SECRET_SERVICE_PREFIX}:${name}" 2>/dev/null
  command security add-generic-password -a "$USER" -s "${_SECRET_SERVICE_PREFIX}:${name}" -l "$name" -w "$secret_value"
  export "$name"="$secret_value"
  echo "Stored and exported $name"
}

secret-get() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: secret-get NAME" >&2
    return 1
  fi
  if ! _secret_name_is_valid "$name"; then
    echo "Secret names must match [A-Za-z_][A-Za-z0-9_]*" >&2
    return 1
  fi
  command security find-generic-password -a "$USER" -s "${_SECRET_SERVICE_PREFIX}:${name}" -w 2>/dev/null
}

secret-del() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: secret-del NAME" >&2
    return 1
  fi
  if ! _secret_name_is_valid "$name"; then
    echo "Secret names must match [A-Za-z_][A-Za-z0-9_]*" >&2
    return 1
  fi
  command security delete-generic-password -a "$USER" -s "${_SECRET_SERVICE_PREFIX}:${name}" &>/dev/null
  unset "$name"
  echo "Removed $name"
}

secret-list() {
  _secret_names
}

# Auto-export all managed secrets on shell startup
_load_secrets() {
  emulate -L zsh
  setopt localoptions typesetsilent
  unsetopt aliases xtrace verbose

  local name secret_value
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    secret_value=$(command security find-generic-password -a "$USER" -s "${_SECRET_SERVICE_PREFIX}:${name}" -w 2>/dev/null) || continue
    [[ -n "$secret_value" ]] || continue
    export "$name"="$secret_value"
  done < <(_secret_names)
}
_load_secrets
